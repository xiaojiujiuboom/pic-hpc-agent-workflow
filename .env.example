# 需要真实远程连接时，把这个文件复制为 .env 再填写。
# 不要把真实密码、私钥提交到 Git。
# 用户名里包含 @ 是正常的，保持原样即可。
BLSC_BASE_URL=https://cloud.blsc.cn/
HPCPIC_SSH_HOST=ssh.cn-hongkong-1.paracloud.com
HPCPIC_SSH_PORT=22
HPCPIC_SSH_USER=你的超算账号@BSCC-M9
HPCPIC_REMOTE_ROOT=~/pic/hpc/runs

# 旧变量名兼容，可不填。
BLSC_SSH_HOST=
BLSC_SSH_USER=
BLSC_REMOTE_ROOT=
