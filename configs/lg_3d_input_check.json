{
  "campaign": "lg_3d_input_check",
  "objective": "validate_lg_3d_deck_syntax",
  "run_root": "runs",
  "database": "runs/campaign.sqlite",
  "epoch": {
    "template": "templates/epoch_lg_3d.deck.tpl",
    "binary": "$HOME/pic/bin/epoch3d",
    "dimensions": 3,
    "final_time_fs": 0.2,
    "domain": {
      "x_min_um": -2.0,
      "x_max_um": 2.0,
      "y_min_um": -2.0,
      "y_max_um": 2.0,
      "z_min_um": -2.0,
      "z_max_um": 2.0
    },
    "grid": {
      "nx": 16,
      "ny": 12,
      "nz": 12
    },
    "particles_per_cell": 1,
    "output": {
      "dt_snapshot_fs": 0.2,
      "fields": "always",
      "density": "always + species",
      "particles": "never",
      "particle_momentum": "never"
    }
  },
  "slurm": {
    "template": "templates/slurm_epoch.slurm.tpl",
    "nodes": 1,
    "ntasks": 1,
    "time": "00:02:00",
    "launcher": "mpirun",
    "env": {
      "OMPI": "/publicfs10/fs10-share/soft/share-soft/openmpi/4.1.1",
      "AOCC": "/publicfs10/fs10-share/soft/share-soft/aocc/5.0.0",
      "HDF5": "/publicfs10/fs10-share/soft/share-soft/hdf5/hdf5-1.14.0-aocc"
    }
  },
  "initial_parameters": [
    {
      "l": 1,
      "p": 0,
      "polarization": "linear_y",
      "a0": 1.0,
      "w0_um": 0.8,
      "tau_fs": 0.1,
      "target": {
        "carbon_thickness_um": 0.4,
        "carbon_density_nc": 1.0,
        "hydrogen_thickness_um": 0.1,
        "hydrogen_density_nc": 1.0,
        "hydrogen_radius_um": 1.0
      }
    }
  ],
  "metrics": [
    "sdf_count",
    "density_plot"
  ]
}
